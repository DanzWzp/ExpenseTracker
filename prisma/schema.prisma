// prisma/schema.prisma

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  // id = UUID dari Supabase Auth (auth.users.id), bukan cuid.
  id                String   @id
  email             String   @unique
  displayName       String?
  profilePictureUrl String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  expenses          Expense[]
  budgets           Budget[]
  goals             Goal[]
  recurringExpenses RecurringExpense[]

  @@map("users")
}

model Expense {
  id                 String   @id @default(cuid())
  userId             String
  amount             Decimal  @db.Decimal(10, 2)
  category           String // Food, Transport, Entertainment, dll
  description        String?  @db.VarChar(500)
  date               DateTime
  paymentMethod      String // Cash, Credit Card, Debit Card, Online Transfer
  recurringExpenseId String? // Tautan ke recurring expense bila ada
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  recurringExpense RecurringExpense? @relation(fields: [recurringExpenseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([date])
  @@index([category])
  @@map("expenses")
}

model RecurringExpense {
  id                String    @id @default(cuid())
  userId            String
  amount            Decimal   @db.Decimal(10, 2)
  category          String
  description       String?   @db.VarChar(500)
  paymentMethod     String
  frequency         String // Weekly, Monthly, Yearly
  startDate         DateTime
  endDate           DateTime?
  isActive          Boolean   @default(true)
  lastGeneratedDate DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@index([userId])
  @@map("recurring_expenses")
}

model Budget {
  id           String   @id @default(cuid())
  userId       String
  category     String
  monthlyLimit Decimal  @db.Decimal(10, 2)
  currentMonth Int // Bulan (1-12)
  currentYear  Int // Tahun
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, currentMonth, currentYear])
  @@index([userId])
  @@map("budgets")
}

model Goal {
  id            String    @id @default(cuid())
  userId        String
  name          String
  targetAmount  Decimal   @db.Decimal(10, 2)
  currentAmount Decimal   @default(0) @db.Decimal(10, 2)
  deadline      DateTime
  description   String?   @db.VarChar(500)
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("goals")
}
