# ─────────────────────────────────────────────────────────────
# SUPABASE (Auth + Realtime)
# Ambil dari: Supabase Dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────────
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOi...your-anon-key"

# ─────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL via Supabase, dipakai oleh Prisma)
# Ambil dari: Supabase Dashboard → Project Settings → Database → Connection string
#
# DATABASE_URL  = koneksi via pooler (port 6543) untuk runtime app.
# DIRECT_URL    = koneksi langsung (port 5432) untuk `prisma migrate`.
# Ganti [PASSWORD] dan [PROJECT-REF] sesuai project-mu.
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"
